# =============================================================================
# SENTRY AI AGENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Sentry Configuration
# -----------------------------------------------------------------------------
SENTRY_WEBHOOK_SECRET=your_sentry_webhook_secret_here
SENTRY_DSN=https://your-sentry-dsn-here

# Sentry API (for bidirectional communication)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG_SLUG=your-organization-slug
SENTRY_PROJECT_SLUG=your-project-slug

# -----------------------------------------------------------------------------
# AI/LLM Configuration
# -----------------------------------------------------------------------------
# Choose your AI provider: 'openai' or 'anthropic'
LLM_PROVIDER=anthropic

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# Anthropic Claude Configuration (if using Claude - RECOMMENDED)
# Claude Sonnet 4.5 is faster and more accurate for code analysis
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=8000

# AI Cost Management
LLM_DAILY_BUDGET=50
LLM_ENABLE_CACHING=true

# -----------------------------------------------------------------------------
# GitHub Configuration
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your-github-personal-access-token-here
GITHUB_OWNER=sarasanalytics-com
GITHUB_DEFAULT_REPO=insights-webapp
GITHUB_DEFAULT_BRANCH=dev
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_BOT_USERNAME=ai-agent

# Repository Mapping (Sentry Project -> GitHub Repo)
# Format: sentry-project:github-repo:branch,another-project:another-repo:branch
# Maps Sentry project slugs to their corresponding GitHub repositories and branches
# Supports wildcards for pattern matching (e.g., saras-iq-*:iq-webapp:dev)
# If branch is omitted, defaults to 'dev'
REPO_MAPPING=daton:daton-webapp:dev,daton-webapp:webapp:dev,saras-iq-*:iq-webapp:dev,insights-webapp:insights-webapp:dev,global-webapp:global-accounts-webapp:dev

# GitHub to Slack user mapping (JSON format)
# Maps GitHub usernames to Slack user IDs for DM notifications
GITHUB_SLACK_USER_MAP={"github_user1":"U12345ABC","github_user2":"U67890DEF"}

# -----------------------------------------------------------------------------
# ClickUp Configuration
# -----------------------------------------------------------------------------
CLICKUP_API_TOKEN=pk_your_clickup_token_here
CLICKUP_WORKSPACE_ID=your_workspace_id
CLICKUP_SPACE_ID=your_space_id
CLICKUP_FOLDER_ID=your_folder_id
CLICKUP_LIST_ID=your_list_id

# -----------------------------------------------------------------------------
# Slack Configuration
# -----------------------------------------------------------------------------
# Option 1: Webhook URL (Simpler - recommended for getting started)
# Get from: Slack App > Incoming Webhooks > Add New Webhook to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXX

# Option 2: Bot Token (More features - threading, file uploads, etc.)
# Get from: Slack App > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_DEFAULT_CHANNEL=#engineering-alerts

# -----------------------------------------------------------------------------
# Safety Constraints
# -----------------------------------------------------------------------------
# File modification limits
SAFETY_MAX_FILES_MODIFIED=2
SAFETY_MAX_LINES_CHANGED=50
SAFETY_MAX_FILE_SIZE=1000

# Confidence thresholds (0.0 - 1.0)
SAFETY_MIN_CONFIDENCE_FOR_PR=0.85
SAFETY_MIN_CONFIDENCE_FOR_SUGGESTION=0.60

# Rate limits
SAFETY_MAX_PRS_PER_HOUR=5
SAFETY_MAX_PRS_PER_DAY=20
SAFETY_MAX_ERRORS_PER_MINUTE=10

# Allowed file extensions (comma-separated)
SAFETY_ALLOWED_EXTENSIONS=.ts,.tsx,.js,.jsx

# Forbidden files (comma-separated)
SAFETY_FORBIDDEN_FILES=package.json,package-lock.json,tsconfig.json,.env,.env.local

# Allowed fix types (comma-separated)
SAFETY_ALLOWED_FIX_TYPES=null-check,optional-chaining,type-guard,undefined-check

# -----------------------------------------------------------------------------
# Code Validation Configuration
# -----------------------------------------------------------------------------
# Enable/disable validation pipeline
VALIDATION_ENABLED=true

# Validation requirements
VALIDATION_REQUIRE_TESTS_PASS=true
VALIDATION_REQUIRE_LINT_PASS=true
VALIDATION_REQUIRE_TYPE_CHECK_PASS=true
VALIDATION_REQUIRE_BUILD_PASS=false

# Validation timeout (milliseconds)
VALIDATION_TIMEOUT=300000

# Validation mode: 'local' or 'ci'
VALIDATION_MODE=local

# CI workflow file (for CI mode)
VALIDATION_CI_WORKFLOW=ci.yml

# -----------------------------------------------------------------------------
# Circuit Breaker Configuration
# -----------------------------------------------------------------------------
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=0.5
CIRCUIT_BREAKER_VALIDATION_FAILURE_THRESHOLD=0.7
CIRCUIT_BREAKER_COOLDOWN_MINUTES=60

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database path
DATABASE_PATH=./data/sentry-ai-agent.db

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable specific features
FEATURE_AUTO_PR_CREATION=true
FEATURE_TICKET_CREATION=true
FEATURE_SLACK_NOTIFICATIONS=true
FEATURE_AUDIT_LOGGING=true

# Operational modes
# Mode: 'ticket-only' | 'suggestion' | 'pr-creation'
OPERATIONAL_MODE=pr-creation

# -----------------------------------------------------------------------------
# Advanced Configuration
# -----------------------------------------------------------------------------
# Timezone for date formatting
TIMEZONE=UTC

# Duplicate detection window (hours)
DUPLICATE_DETECTION_WINDOW=24

# PR settings
PR_ALWAYS_DRAFT=true
PR_REQUIRE_HUMAN_REVIEW=true
PR_AUTO_ASSIGN=true
PR_DEFAULT_REVIEWERS=

# Retry configuration
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=2000

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Enable metrics collection
METRICS_ENABLED=true
METRICS_PORT=9090

# Enable health check endpoint
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
